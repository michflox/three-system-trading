# Coinbase CDP credentials. COINBASE_API_KEY is the resource name, e.g.
# organizations/{org_id}/apiKeys/{key_id}. COINBASE_API_SECRET is the PEM
# private key (EC or Ed25519 both work — see crypto/adapters/coinbase.py).
#
# IMPORTANT: systemd's EnvironmentFile= parser (systemd >= 253, e.g. Ubuntu
# 24.04's systemd 255) applies shell-like backslash escaping and will
# silently strip a literal "\n" used to flatten a multi-line PEM onto one
# line — this corrupts the key with no error until the service actually
# starts (manual `source`-based testing will NOT catch it). Do not use a
# \n-escaped single-line PEM here. Instead wrap the value in double quotes
# and paste the PEM with its real line breaks preserved, e.g.:
#
# COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----
# MHcCAQEE...
# -----END EC PRIVATE KEY-----"
COINBASE_API_KEY=
COINBASE_API_SECRET=
TRADING_DATA_DIR=/var/lib/trading-bot/data
TRADING_REPORT_DIR=/var/lib/trading-bot/reports
# CDE nano perpetual product IDs. Update at contract rollover (current expiry Dec 2030).
COINBASE_CFM_SYMBOLS=BIP-20DEC30-CDE,ETP-20DEC30-CDE,SLP-20DEC30-CDE
SPOT_BACKFILL_START=2015-01-01T00:00:00+00:00
FUNDING_BACKFILL_START=2025-07-21
MINIMUM_DISK_FREE_PERCENT=15
LOG_LEVEL=INFO

