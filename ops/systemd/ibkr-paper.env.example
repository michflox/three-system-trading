# Paper account only. The adapter rejects accounts that do not start with DU.
IBKR_ACCOUNT=DU_REPLACE_ME
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=21
TRADING_STATE_DB=/var/lib/trading-bot/state/ibkr-paper.db
IBKR_STOP_REPORT=/var/lib/trading-bot/reports/ibkr-stop-verification-latest.json

# Used only by the opt-in, read-only integration test. Keep current expiries here,
# not in source code; stale contract guesses must fail rather than silently roll.
RUN_LIVE_IBKR_TESTS=0
IBKR_TEST_CONTRACT_MONTHS={"MES":"YYYYMM","MNQ":"YYYYMM","M2K":"YYYYMM","MYM":"YYYYMM","MGC":"YYYYMM","MHG":"YYYYMM","MCL":"YYYYMM","MNG":"YYYYMM","M6E":"YYYYMM","M6B":"YYYYMM","M6A":"YYYYMM"}
