# Start in DRY_RUN. Change to PAPER only after 48 continuous clean hours.
TRADING_EXECUTION_MODE=DRY_RUN
TRADING_DATA_DIR=/var/lib/trading-bot/data
TRADING_REPORT_DIR=/var/lib/trading-bot/reports
TRADING_STATE_DB=/var/lib/trading-bot/state/crypto-paper.db
TRADING_JOURNAL=/var/log/trading-bot/crypto-paper.jsonl
TRADING_RISK_CONFIG=/opt/trading-bot/config/crypto_paper.json
TRADING_HEARTBEAT=/var/lib/trading-bot/run/crypto-paper-heartbeat.json
PAPER_INITIAL_EQUITY=100000

# Populate from authenticated venue fee endpoints; never commit account credentials.
COINBASE_MAKER_FEE=
COINBASE_TAKER_FEE=
KRAKEN_MAKER_FEE=
KRAKEN_TAKER_FEE=
LIVE_BACKTEST_COST_TOLERANCE=0.005

# Telegram Bot API credentials are secrets and belong only in /etc/trading-bot/crypto-paper.env.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LOG_LEVEL=INFO
